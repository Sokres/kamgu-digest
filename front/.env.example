# Базовый URL FastAPI (без завершающего слэша). В UI можно переопределить в «Настройки» (localStorage).
VITE_API_BASE_URL=http://localhost:8080

# Опционально: заголовок X-Internal-Key для POST /digests/monthly, если на бэкенде задан MONTHLY_DIGEST_CRON_SECRET.
# В приложении ключ можно задать и в настройках.
# VITE_MONTHLY_INTERNAL_KEY=
