# Ключ должен совпадать с OPENAI_BASE_URL:
# — OpenRouter → sk-or-v1-... с https://openrouter.ai/keys (НЕ sk-proj от OpenAI)
# — Нативный OpenAI → sk-proj-... и OPENAI_BASE_URL=https://api.openai.com/v1
# Если OPENAI_BASE_URL=openrouter — в приоритете OPENROUTER_API_KEY; закомментируйте OPENAI_API_KEY, чтобы не путаться.
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
# OPENAI_API_KEY=

OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Стабильнее: платная/дешёвая openai/gpt-4o-mini (нужен баланс на OpenRouter). :free часто 429 у Venice.
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_RESPONSE_FORMAT_JSON=true
# При :free моделях поставьте false и увеличьте ретраи:
LLM_MAX_RETRIES=8
LLM_RETRY_BASE_SECONDS=4
# Лимиты символов abstract на публикацию в промпте LLM (метаданные vs длинные PDF/OA-отрывки)
# LLM_MAX_ABSTRACT_CHARS_PER_PUB=12000
# LLM_MAX_ABSTRACT_CHARS_LONGTEXT=24000
# Двухэтапный дайджест при оценке JSON user payload больше порога (символы)
# LLM_DIGEST_PROMPT_BUDGET_CHARS=900000
# LLM_DIGEST_MAP_CONCURRENCY=3

# Опционально (рекомендуется OpenRouter для рейтинга приложений)
OPENROUTER_HTTP_REFERER=http://localhost:8080
OPENROUTER_APP_TITLE=KamGU Research Digest

# Нативный OpenAI (если не используете OpenRouter) — закомментируйте блок выше и раскомментируйте:
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_RESPONSE_FORMAT_JSON=true

# Контакт в User-Agent (OpenAlex + уменьшает 403 у Semantic Scholar). Также используется как email для Unpaywall API (OA PDF по DOI), если UNPAYWALL_EMAIL не задан.
# OPENALEX_MAILTO=you@university.edu
# API-ключ OpenAlex (https://openalex.org/settings/api): 10× дневной лимит ($1/день бесплатно). Без ключа базовые запросы тоже работают ($0.10/день).
# OPENALEX_API_KEY=
# Явный email для Unpaywall (https://unpaywall.org/products/api) — для fetch_oa_fulltext в POST /digests
# UNPAYWALL_EMAIL=you@university.edu
# Кэш извлечённого текста по DOI и лимиты загрузки
# OA_FULLTEXT_CACHE_DIR=data/oa_fulltext_cache
# OA_FULLTEXT_MAX_PER_DIGEST=8
# OA_FULLTEXT_MAX_DOWNLOAD_BYTES=26214400
# Или явно:
# HTTP_USER_AGENT=KamGU-Digest/1.0 (mailto:you@university.edu)

HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=5
SOURCE_STAGGER_SECONDS=1.5
SEMANTIC_SCHOLAR_PAGE_DELAY_SECONDS=5
# SEMANTIC_SCHOLAR_API_KEY=
# При постоянных 429 — только OpenAlex:
SEMANTIC_SCHOLAR_ENABLED=false
SEMANTIC_SCHOLAR_MAX_RETRIES=12

# CORE REST v3 — поиск по открытому доступу; ключ в кабинете CORE (https://core.ac.uk/)
# CORE_ENABLED=true
# CORE_API_KEY=
# Пауза между запросами (квота ~1 batch / 10 с)
# CORE_REQUEST_DELAY_SECONDS=10.5
# CORE_MAX_PAGES=5

# Crossref: обогащение метаданных по DOI после сбора (без ключа)
# CROSSREF_ENRICHMENT_ENABLED=true
# CROSSREF_MAX_UNIQUE_DOIS=80

LOG_LEVEL=INFO

# CORS для браузерного фронта (через запятую). Пусто — отключить. «*» — любой origin.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Ежемесячный дайджест: снимки в PostgreSQL (по умолчанию как в docker-compose) или SQLite локально
# SNAPSHOT_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/kamgu_digest
# Без Docker: SNAPSHOT_DATABASE_URL=sqlite:///./snapshots.db
# Опционально: защитить POST /digests/periodic и /digests/monthly (тот же ключ в заголовке X-Internal-Key)
# MONTHLY_DIGEST_CRON_SECRET=
# Встроенный планировщик расписаний (GET/POST /digests/schedules): только при одном воркере uvicorn.
# DIGEST_PERIODIC_SCHEDULER_ENABLED=false

# Опционально: письмо после каждого запуска расписания (встроенный планировщик). Без SMTP_HOST или DIGEST_NOTIFY_TO_EMAIL — не отправляется.
# SMTP_HOST=smtp.example.org
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true
# DIGEST_NOTIFY_FROM_EMAIL=digest@example.org
# DIGEST_NOTIFY_TO_EMAIL=teamlead@university.edu,colleague@university.edu

# Опционально: HTTP POST (JSON) после каждого запуска встроенного планировщика (успех или ошибка). Пустой URL — не вызывать.
# DIGEST_SCHEDULE_WEBHOOK_URL=https://example.org/hooks/digest
# Опционально: общий секрет в заголовке X-Webhook-Secret для вашего приёмника.
# DIGEST_SCHEDULE_WEBHOOK_SECRET=

# Лимит POST /digests на IP (запросов в минуту, скользящее окно 60 с). 0 = отключено.
# DIGEST_RATE_LIMIT_PER_MINUTE=0
# POST /saved-digests: макс. размер JSON (байты)
# SAVED_DIGEST_MAX_PAYLOAD_BYTES=4194304
# SAVED_DIGEST_TITLE_MAX_LENGTH=200

# Пользователи (JWT): снимки, тренды, расписания и PDF в разрезе user_id. Без AUTH — режим как раньше (legacy tenant).
# AUTH_ENABLED=false
# AUTH_JWT_SECRET=замените_на_длинную_случайную_строку
# Access JWT (если не задано — используется AUTH_JWT_EXPIRE_MINUTES):
# AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60
# Refresh-токены в БД, срок жизни серверной сессии (дни):
# AUTH_REFRESH_TOKEN_EXPIRE_DAYS=30
# AUTH_JWT_EXPIRE_MINUTES=10080
# AUTH_REGISTRATION_ENABLED=true
# AUTH_LEGACY_USER_ID=__legacy__

# Загрузка PDF для дайджеста (каталог uuid.pdf + uuid.json; в .gitignore)
# DOCUMENTS_STORAGE_DIR=data/documents
# PDF_MAX_UPLOAD_BYTES=20971520
# PDF_MAX_PAGES_EXTRACT=80
# PDF_MAX_ABSTRACT_CHARS=50000

# Веб-обзор (digest_mode=web_snippets на /digests): https://tavily.com
# Ключ выглядит как tvly-dev-... или tvly-... (скопируйте из кабинета Tavily)
# TAVILY_API_KEY=tvly-dev-REPLACE_ME
# WEB_SEARCH_MAX_RESULTS=15
# По умолчанию веб-поиск ограничен научными доменами (см. DEFAULT_SCHOLARLY_DOMAINS в sources/tavily.py).
# Переопределить список (через запятую, без https://):
# TAVILY_INCLUDE_DOMAINS=arxiv.org,pubmed.ncbi.nlm.nih.gov,nature.com
# Необязательный префикс к запросу Tavily (смещает выдачу к статьям):
# TAVILY_QUERY_PREFIX=peer-reviewed research publication

