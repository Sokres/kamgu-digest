# --- LLM (активен OpenRouter; для DeepSeek/OpenAI — блок B/C) ---
#
# A) OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
# OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_RESPONSE_FORMAT_JSON=true
#
# B) DeepSeek — https://platform.deepseek.com
