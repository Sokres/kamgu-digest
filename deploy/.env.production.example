# Скопируйте в корень репозитория как .env рядом с docker-compose.prod.yml
# и объедините с переменными из backend/.env.example (LLM, HTTP, CORS и т.д.).

# --- PostgreSQL (docker-compose.prod.yml) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG
POSTGRES_DB=kamgu_digest

# SNAPSHOT_DATABASE_URL для контейнера api задаётся в docker-compose.prod.yml
# (подключение к сервису postgres по внутренней сети). Не указывайте 127.0.0.1.

# --- Прод (пример; см. backend/.env.example) ---
# OPENROUTER_API_KEY=...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# CORS_ORIGINS=https://app.example.com
# MONTHLY_DIGEST_CRON_SECRET=...   # POST /digests/periodic и /digests/monthly
# DIGEST_RATE_LIMIT_PER_MINUTE=30  # опционально: лимит POST /digests с одного IP
