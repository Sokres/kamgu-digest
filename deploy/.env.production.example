# Скопируйте в корень репозитория как .env рядом с docker-compose.prod.yml
# и объедините с переменными из backend/.env.example (LLM, HTTP, CORS и т.д.).

# --- PostgreSQL (docker-compose.prod.yml) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG
POSTGRES_DB=kamgu_digest

# URL к PostgreSQL внутри Docker (хост postgres). Пароль с символами @ : / ? ломает URL без кодирования.
# Сгенерируйте одну строку и вставьте в .env (из корня репозитория):
#   python3 deploy/snapshot_dsn.py
#   → добавьте в .env: SNAPSHOT_DATABASE_URL=<вывод скрипта>
SNAPSHOT_DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG@postgres:5432/kamgu_digest

# --- Фронт (сборка на сервере в deploy/remote-update.sh; нужен Node.js + npm) ---
# VITE_API_BASE_URL=https://api.example.com
# Опционально: куда скопировать dist, если Caddy/Nginx смотрят не в /opt/kamgu/front/dist
# FRONT_STATIC_ROOT=/var/www/kamgu/front/dist
# DEPLOY_BUILD_FRONT=0   # отключить npm run build при деплое

# --- Прод (пример; см. backend/.env.example) ---
# OPENROUTER_API_KEY=...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Публичный URL страницы (не API). Для kamgu.24msg.ru + api.24msg.ru задайте:
CORS_ORIGINS=https://kamgu.24msg.ru
# MONTHLY_DIGEST_CRON_SECRET=...   # POST /digests/periodic и /digests/monthly
# DIGEST_RATE_LIMIT_PER_MINUTE=30  # опционально: лимит POST /digests с одного IP
# CORE: https://core.ac.uk/api-keys/register — CORE_ENABLED=true, CORE_API_KEY=...
