# Пример: API на поддомене, фронт на другом поддомене.
# Установите Caddy на хосте, подставьте домены и пути к dist.
#
# Глобально: клиент может ждать ответ POST /digests несколько минут без единого байта.
# {
# 	servers {
# 		timeouts {
# 			read_body 2m
# 			write 20m
# 			idle 20m
# 		}
# 	}
# }
#
# api.example.com {
#   reverse_proxy 127.0.0.1:8080 {
#     flush_interval -1
#     transport http {
#       dial_timeout 30s
#       read_timeout 20m
#       write_timeout 20m
#       keepalive off
#     }
#   }
# }
#
# app.example.com {
#   root * /var/www/kamgu/front/dist
#   file_server
#   try_files {path} /index.html
# }
